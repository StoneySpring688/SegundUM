						{ "listen": "test", "script": { "exec": [
							"pm.test('Vendedor registrado (201)', function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"if (pm.response.code === 200 || pm.response.code === 201) {",
							"    var body = pm.response.text().replace(/\\\"/g, '');",
